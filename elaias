// Caminho: src/lib/melodyScanner.ts

export class MelodyScannerLib {
  private apiToken: string;
  private baseUrl: string;

  constructor(apiToken: string) {
    if (!apiToken) {
      throw new Error("MelodyScanner: API Token é obrigatório.");
    }
    this.apiToken = apiToken;
    // Usando a API AudD para reconhecimento de áudio
    this.baseUrl = "https://api.audd.io/"; 
  }

  /**
   * Envia um arquivo de áudio para ser reconhecido pela API.
   * Retorna os metadados da música limpos.
   */
  async identifyAudio(audioFile: File | Blob) {
    const formData = new FormData();
    formData.append("file", audioFile);
    formData.append("api_token", this.apiToken);

    try {
      // Usando fetch nativo, sem axios, sem SDK. Leve e rápido.
      const response = await fetch(this.baseUrl, {
        method: "POST",
        body: formData,
      });

      if (!response.ok) {
        throw new Error(`Falha na comunicação com a API: Status ${response.status}`);
      }

      const data = await response.json();

      // Tratamento de erro específico da API
      if (data.status === "error") {
        throw new Error(`Erro na API de Áudio: ${data.error.error_message}`);
      }

      if (!data.result) {
        return null; // Nenhuma música encontrada
      }

      // Normaliza o retorno (O Contrato da sua Lib com o seu App)
      // O seu banco de dados ou UI não precisa saber como a API externa funciona.
      return {
        providerId: data.result.song_link, 
        title: data.result.title,
        artist: data.result.artist,
        album: data.result.album,
        releaseDate: data.result.release_date,
        spotifyUrl: data.result.spotify?.external_urls?.spotify || null
      };

    } catch (error) {
      console.error("[MelodyScannerLib] Erro ao identificar áudio:", error);
      throw error; 
    }
  }
}
